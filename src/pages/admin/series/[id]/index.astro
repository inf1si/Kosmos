---
import Layout from "../../../../layouts/Layout.astro";
import { auth } from "../../../../lib/auth";
import { db } from "../../../../lib/db/client";
import { series, chapter } from "../../../../lib/db/schema";
import { asc, eq } from "drizzle-orm";

export const prerender = false;

const session = await auth.api.getSession({ headers: Astro.request.headers });
if (!session) return Astro.redirect("/admin/login");

const { id } = Astro.params;
if (!id) return Astro.redirect("/admin");

const s = await db.select().from(series).where(eq(series.id, id)).get();
if (!s) return new Response("Not found", { status: 404 });

const chapters = await db
  .select()
  .from(chapter)
  .where(eq(chapter.seriesId, s.id))
  .orderBy(asc(chapter.number))
  .all();
---

<Layout title={`관리 · ${s.title}`} scope="admin">
  <nav class="text-sm text-gray-500 mb-6">
    <a href="/admin" class="hover:text-gray-900">← 관리</a>
  </nav>

  <div class="flex items-start justify-between mb-12 gap-6">
    <div class="min-w-0">
      <h1 class="wordmark text-3xl mb-1 truncate">{s.title}</h1>
      <div class="meta-line">{s.kind} · {s.status}</div>
      {s.synopsis && <p class="mt-3 text-sm text-gray-700 max-w-prose">{s.synopsis}</p>}
    </div>
    <div class="flex items-center gap-3 shrink-0">
      <a href={`/admin/series/${s.id}/edit`} class="btn-ghost">수정</a>
      <a href={`/s/${s.slug}`} class="btn-ghost">독자 페이지 →</a>
    </div>
  </div>

  <div class="flex items-baseline justify-between mb-4">
    <h2 class="section-label">화 · {chapters.length}</h2>
    <a href={`/admin/series/${s.id}/chapters/new`} class="text-sm text-[color:var(--color-accent)] hover:underline">
      + 새 화
    </a>
  </div>

  {chapters.length === 0 ? (
    <p class="font-serif italic text-gray-500 text-sm">아직 화가 없습니다.</p>
  ) : (
    <ul class="hairline-list">
      {chapters.map((c) => (
        <li>
          <div class="flex items-baseline gap-4 flex-1 min-w-0">
            <span class="meta-line tabular-nums text-sm w-10 text-right shrink-0">{c.number}</span>
            <span class="font-medium truncate flex-1">{c.title}</span>
            {c.status !== "발행" && (
              <span class="meta-line text-xs shrink-0">— {c.status}</span>
            )}
          </div>
          <div class="flex items-center gap-3 shrink-0">
            <a href={`/admin/series/${s.id}/chapters/${c.id}/edit`} class="btn-ghost">수정</a>
            {c.status === "발행" && (
              <a href={`/s/${s.slug}/${c.number}`} class="btn-ghost">미리보기 →</a>
            )}
          </div>
        </li>
      ))}
    </ul>
  )}
</Layout>
