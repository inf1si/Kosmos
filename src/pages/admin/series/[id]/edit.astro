---
import Layout from "../../../../layouts/Layout.astro";
import { auth } from "../../../../lib/auth";
import { db } from "../../../../lib/db/client";
import { series } from "../../../../lib/db/schema";
import { eq } from "drizzle-orm";

export const prerender = false;

const session = await auth.api.getSession({ headers: Astro.request.headers });
if (!session) return Astro.redirect("/admin/login");

const { id } = Astro.params;
if (!id) return Astro.redirect("/admin");

const s = await db.select().from(series).where(eq(series.id, id)).get();
if (!s) return new Response("Not found", { status: 404 });
---

<Layout title={`수정 · ${s.title}`} scope="admin">
  <nav class="text-sm text-gray-500 mb-6">
    <a href={`/admin/series/${s.id}`} class="hover:text-gray-900">← {s.title}</a>
  </nav>
  <h1 class="wordmark text-3xl mb-10">작품 수정</h1>

  <form id="edit-series" class="grid gap-5 max-w-lg" data-id={s.id}>
    <label class="label">
      <span class="label-text">제목</span>
      <input name="title" value={s.title} required class="input" />
    </label>

    <label class="label">
      <span class="label-text">슬러그 (URL)</span>
      <input name="slug" value={s.slug} required pattern="[a-z0-9-]+" class="input input-mono" />
    </label>

    <label class="label">
      <span class="label-text">유형</span>
      <select name="kind" required class="input">
        <option value="장편" selected={s.kind === "장편"}>장편</option>
        <option value="단편" selected={s.kind === "단편"}>단편</option>
      </select>
    </label>

    <label class="label">
      <span class="label-text">상태</span>
      <select name="status" required class="input">
        <option value="연재중" selected={s.status === "연재중"}>연재중</option>
        <option value="완결" selected={s.status === "완결"}>완결</option>
        <option value="휴재" selected={s.status === "휴재"}>휴재</option>
      </select>
    </label>

    <label class="label">
      <span class="label-text">시놉시스</span>
      <textarea name="synopsis" rows="4" class="input">{s.synopsis ?? ""}</textarea>
    </label>

    <div class="flex items-center gap-2 mt-2">
      <button type="submit" class="btn btn-primary">저장</button>
      <a href={`/admin/series/${s.id}`} class="btn btn-secondary">취소</a>
      <button type="button" id="delete-btn" class="btn-danger ml-auto">작품 삭제</button>
    </div>
    <p id="msg" class="text-sm text-red-700"></p>
  </form>
</Layout>

<script>
  const form = document.getElementById("edit-series") as HTMLFormElement;
  const msg = document.getElementById("msg") as HTMLElement;
  const id = form.dataset.id;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    msg.textContent = "";
    const body = Object.fromEntries(new FormData(form).entries());
    const res = await fetch(`/api/series/${id}`, {
      method: "PATCH",
      headers: { "content-type": "application/json" },
      body: JSON.stringify(body),
    });
    if (res.ok) {
      window.location.href = `/admin/series/${id}`;
    } else {
      const err = await res.json().catch(() => ({ error: "저장 실패" }));
      msg.textContent = err.error ?? "오류";
    }
  });

  document.getElementById("delete-btn")!.addEventListener("click", async () => {
    if (!confirm("이 작품과 그 아래 모든 화를 정말 삭제할까요?")) return;
    const res = await fetch(`/api/series/${id}`, { method: "DELETE" });
    if (res.ok) {
      window.location.href = "/admin";
    } else {
      msg.textContent = "삭제 실패";
    }
  });
</script>
