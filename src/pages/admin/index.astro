---
import Layout from "../../layouts/Layout.astro";
import { auth } from "../../lib/auth";
import { db } from "../../lib/db/client";
import { series, wikiPage } from "../../lib/db/schema";
import { desc } from "drizzle-orm";

export const prerender = false;

const session = await auth.api.getSession({ headers: Astro.request.headers });
if (!session) return Astro.redirect("/admin/login");

const [seriesList, wikiList] = await Promise.all([
  db.select().from(series).orderBy(desc(series.updatedAt)).all(),
  db.select().from(wikiPage).orderBy(desc(wikiPage.updatedAt)).all(),
]);
---

<Layout title="관리" scope="admin">
  <div class="flex items-baseline justify-between mb-12">
    <h1 class="wordmark text-3xl">관리</h1>
    <span class="meta-line text-xs">{session.user.email}</span>
  </div>

  <section class="mb-14">
    <div class="flex items-baseline justify-between mb-4">
      <h2 class="section-label">작품 · {seriesList.length}</h2>
      <a href="/admin/series/new" class="text-sm text-[color:var(--color-accent)] hover:underline">
        + 새 작품
      </a>
    </div>

    {seriesList.length === 0 ? (
      <p class="font-serif italic text-gray-500 text-sm">없음</p>
    ) : (
      <ul class="hairline-list">
        {seriesList.map((s) => (
          <li>
            <a href={`/admin/series/${s.id}`} class="flex-1 min-w-0">
              <div class="font-medium truncate">{s.title}</div>
              <div class="meta-line text-xs">{s.kind} · {s.status}</div>
            </a>
            <a href={`/s/${s.slug}`} class="btn-ghost shrink-0">미리보기 →</a>
          </li>
        ))}
      </ul>
    )}
  </section>

  <section>
    <div class="flex items-baseline justify-between mb-4">
      <h2 class="section-label">위키 · {wikiList.length}</h2>
      <a href="/admin/wiki/new" class="text-sm text-[color:var(--color-accent)] hover:underline">
        + 새 문서
      </a>
    </div>

    {wikiList.length === 0 ? (
      <p class="font-serif italic text-gray-500 text-sm">없음</p>
    ) : (
      <ul class="hairline-list">
        {wikiList.map((w) => (
          <li>
            <div class="flex-1 min-w-0">
              <div class="font-medium truncate">{w.title}</div>
              {w.summary && <div class="meta-line text-xs truncate">{w.summary}</div>}
            </div>
            <div class="flex items-center gap-3 shrink-0">
              <a href={`/admin/wiki/${w.id}/edit`} class="btn-ghost">수정</a>
              <a href={`/wiki/${w.slug}`} class="btn-ghost">미리보기 →</a>
            </div>
          </li>
        ))}
      </ul>
    )}
  </section>
</Layout>
