---
import Layout from "../../layouts/Layout.astro";
import { db } from "../../lib/db/client";
import { wikiPage, series } from "../../lib/db/schema";
import { desc, eq } from "drizzle-orm";
import { auth } from "../../lib/auth";

const session = await auth.api.getSession({ headers: Astro.request.headers });

const pages = await db
  .select({
    id: wikiPage.id,
    slug: wikiPage.slug,
    title: wikiPage.title,
    summary: wikiPage.summary,
    seriesTitle: series.title,
  })
  .from(wikiPage)
  .leftJoin(series, eq(wikiPage.seriesId, series.id))
  .orderBy(desc(wikiPage.updatedAt))
  .all();

// Group by series
const groups = new Map<string, typeof pages>();
for (const p of pages) {
  const key = p.seriesTitle ?? "__global__";
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(p);
}
---

<Layout title="위키">
  <header class="mb-10">
    <div class="flex items-baseline justify-between gap-4">
      <h1 class="wordmark text-4xl leading-tight">위키</h1>
      {session && (
        <a href="/admin/wiki/new" class="author-mark">+ 새 문서</a>
      )}
    </div>
    <p class="text-gray-600 text-sm mt-3">세계관 · 인물 · 용어</p>
  </header>

  {pages.length === 0 ? (
    <p class="text-gray-500 text-sm">아직 문서가 없습니다.</p>
  ) : (
    <div class="space-y-10">
      {[...groups.entries()].map(([groupKey, items]) => (
        <section>
          <h2 class="text-sm font-semibold text-gray-500 tracking-widest uppercase mb-4">
            {groupKey === "__global__" ? "전역" : groupKey}
          </h2>
          <ul class="divide-y divide-gray-200/70 border-y border-gray-200/70">
            {items.map((p) => (
              <li>
                <a href={`/wiki/${p.slug}`} class="flex items-baseline gap-4 py-3 px-1 hover:bg-gray-50/50">
                  <span class="font-medium min-w-fit">{p.title}</span>
                  {p.summary && (
                    <span class="text-sm text-gray-500 line-clamp-1">{p.summary}</span>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  )}
</Layout>
