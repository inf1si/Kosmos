---
import Layout from "../../layouts/Layout.astro";
import { db } from "../../lib/db/client";
import { wikiPage, link, chapter, series } from "../../lib/db/schema";
import { and, eq } from "drizzle-orm";
import { auth } from "../../lib/auth";

const { slug } = Astro.params;
if (!slug) return new Response("Not found", { status: 404 });

const p = await db.select().from(wikiPage).where(eq(wikiPage.slug, slug)).get();
if (!p) return new Response("Not found", { status: 404 });

const parentSeries = p.seriesId
  ? await db.select().from(series).where(eq(series.id, p.seriesId)).get()
  : null;

const backlinks = await db
  .select({
    chapterId: chapter.id,
    chapterNumber: chapter.number,
    chapterTitle: chapter.title,
    seriesTitle: series.title,
    seriesSlug: series.slug,
  })
  .from(link)
  .innerJoin(chapter, and(eq(link.fromType, "chapter"), eq(link.fromId, chapter.id)))
  .innerJoin(series, eq(chapter.seriesId, series.id))
  .where(and(eq(link.toType, "wiki"), eq(link.toId, p.id)))
  .all();

const session = await auth.api.getSession({ headers: Astro.request.headers });
---

<Layout title={p.title}>
  <nav class="text-sm text-gray-500 mb-6">
    <a href="/wiki" class="hover:text-gray-900">← 위키</a>
    {parentSeries && (
      <>
        <span class="mx-1 text-gray-300">/</span>
        <span>{parentSeries.title}</span>
      </>
    )}
  </nav>

  <header class="mb-8 pb-5 border-b border-gray-200/70">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h1 class="wordmark text-4xl leading-tight mb-2">{p.title}</h1>
        {p.summary && <p class="text-gray-600">{p.summary}</p>}
      </div>
      {session && (
        <a href={`/admin/wiki/${p.id}/edit`} class="author-mark shrink-0 mt-2">
          ✎ 수정
        </a>
      )}
    </div>
  </header>

  <article class="prose max-w-none" set:html={p.contentHtml ?? ""} />

  {backlinks.length > 0 && (
    <section class="mt-16 pt-6 border-t border-gray-200/70">
      <h2 class="text-sm font-semibold text-gray-500 tracking-widest uppercase mb-4">
        등장한 화
      </h2>
      <ul class="space-y-1.5 text-sm">
        {backlinks.map((b) => (
          <li>
            <a href={`/s/${b.seriesSlug}/${b.chapterNumber}`} class="text-gray-700 hover:text-gray-900 hover:underline">
              <span class="text-gray-400 mr-2">{b.seriesTitle}</span>
              {b.chapterNumber}화 · {b.chapterTitle}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}
</Layout>
