---
import Layout from "../../../layouts/Layout.astro";
import { db } from "../../../lib/db/client";
import { series, chapter } from "../../../lib/db/schema";
import { eq, and, asc, gt, lt, desc } from "drizzle-orm";
import { auth } from "../../../lib/auth";

const { slug, chapterNo } = Astro.params;
if (!slug || !chapterNo) return new Response("Not found", { status: 404 });

const num = Number(chapterNo);
if (!Number.isFinite(num)) return new Response("Invalid chapter", { status: 400 });

const s = await db.select().from(series).where(eq(series.slug, slug)).get();
if (!s) return new Response("Not found", { status: 404 });

const c = await db
  .select()
  .from(chapter)
  .where(and(eq(chapter.seriesId, s.id), eq(chapter.number, num)))
  .get();
if (!c) return new Response("Not found", { status: 404 });

const [prev, next] = await Promise.all([
  db.select().from(chapter)
    .where(and(eq(chapter.seriesId, s.id), lt(chapter.number, num)))
    .orderBy(desc(chapter.number)).limit(1).get(),
  db.select().from(chapter)
    .where(and(eq(chapter.seriesId, s.id), gt(chapter.number, num)))
    .orderBy(asc(chapter.number)).limit(1).get(),
]);

const session = await auth.api.getSession({ headers: Astro.request.headers });
---

<Layout title={`${c.number}화 ${c.title} — ${s.title}`}>
  <nav class="text-sm text-gray-500 mb-8">
    <a href={`/s/${s.slug}`} class="hover:text-gray-900">← {s.title}</a>
  </nav>

  <header class="mb-10 pb-6 border-b border-gray-200/70">
    <div class="flex items-start justify-between gap-4">
      <div>
        <div class="text-sm text-gray-500 tabular-nums mb-1">{c.number}화</div>
        <h1 class="wordmark text-3xl sm:text-4xl leading-tight">{c.title}</h1>
      </div>
      {session && (
        <a href={`/admin/series/${s.id}/chapters/${c.id}/edit`} class="author-mark shrink-0 mt-2">
          ✎ 이 화 수정
        </a>
      )}
    </div>
  </header>

  <article class="prose max-w-none" set:html={c.contentHtml ?? ""} />

  <nav class="mt-14 pt-6 border-t border-gray-200/70 grid grid-cols-2 gap-3 text-sm">
    {prev ? (
      <a href={`/s/${s.slug}/${prev.number}`} class="card p-4 text-left">
        <div class="text-xs text-gray-500 mb-1">← 이전 화</div>
        <div class="font-medium line-clamp-1">{prev.number}화 {prev.title}</div>
      </a>
    ) : <div />}
    {next ? (
      <a href={`/s/${s.slug}/${next.number}`} class="card p-4 text-right">
        <div class="text-xs text-gray-500 mb-1">다음 화 →</div>
        <div class="font-medium line-clamp-1">{next.number}화 {next.title}</div>
      </a>
    ) : <div />}
  </nav>
</Layout>
