---
import Layout from "../../../layouts/Layout.astro";
import { db } from "../../../lib/db/client";
import { series, chapter } from "../../../lib/db/schema";
import { eq, asc } from "drizzle-orm";
import { auth } from "../../../lib/auth";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/");

const s = await db.select().from(series).where(eq(series.slug, slug)).get();
if (!s) return new Response("Not found", { status: 404 });

const chapters = await db
  .select()
  .from(chapter)
  .where(eq(chapter.seriesId, s.id))
  .orderBy(asc(chapter.number))
  .all();

const isShort = s.kind === "단편";
const first = chapters[0];

const session = await auth.api.getSession({ headers: Astro.request.headers });
---

<Layout title={s.title}>
  <header class="mb-12">
    <h1 class="wordmark text-4xl sm:text-5xl leading-tight mb-3">{s.title}</h1>
    <div class="meta-line mb-5">
      {s.kind}<span class="dot">·</span>{s.status}
      {!isShort && <><span class="dot">·</span>{chapters.length}화</>}
    </div>
    {s.synopsis && (
      <p class="font-serif text-[1.02rem] text-gray-700 leading-relaxed max-w-prose">
        {s.synopsis}
      </p>
    )}

    {session && (
      <div class="mt-5 flex gap-4">
        <a href={`/admin/series/${s.id}/edit`} class="author-mark">✎ 작품 수정</a>
        {isShort && first ? (
          <a href={`/admin/series/${s.id}/chapters/${first.id}/edit`} class="author-mark">✎ 본문 수정</a>
        ) : (
          <a href={`/admin/series/${s.id}/chapters/new`} class="author-mark">+ 새 화</a>
        )}
      </div>
    )}
  </header>

  {isShort && first ? (
    <>
      <div class="flex items-center justify-between mb-6 pb-4 border-b border-gray-200/70">
        <h2 class="wordmark text-xl text-gray-800">{first.title}</h2>
      </div>
      <article class="prose max-w-none" set:html={first.contentHtml ?? ""} />
    </>
  ) : (
    <section>
      <h2 class="text-sm font-semibold text-gray-500 tracking-widest uppercase mb-5">
        목차 · {chapters.length}화
      </h2>
      {chapters.length === 0 ? (
        <p class="text-gray-500 text-sm">아직 등록된 화가 없습니다.</p>
      ) : (
        <ol class="divide-y divide-gray-200/70 border-y border-gray-200/70">
          {chapters.map((c) => (
            <li>
              <a href={`/s/${s.slug}/${c.number}`} class="flex items-baseline gap-4 py-3 px-1 hover:bg-gray-50/50">
                <span class="w-10 text-sm text-gray-400 tabular-nums text-right">{c.number}</span>
                <span class="flex-1 font-medium">{c.title}</span>
                {c.status !== "발행" && (
                  <span class="text-xs text-amber-700">{c.status}</span>
                )}
              </a>
            </li>
          ))}
        </ol>
      )}
    </section>
  )}
</Layout>
