---
import Layout from "../../../layouts/Layout.astro";
import { db } from "../../../lib/db/client";
import { series, chapter } from "../../../lib/db/schema";
import { eq, asc } from "drizzle-orm";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/");

const s = await db.select().from(series).where(eq(series.slug, slug)).get();
if (!s) return new Response("Not found", { status: 404 });

const chapters = await db
  .select()
  .from(chapter)
  .where(eq(chapter.seriesId, s.id))
  .orderBy(asc(chapter.number))
  .all();

// 단편이면 본문을 바로 보여줌 (ch 1)
const isShort = s.kind === "단편";
const first = chapters[0];
---

<Layout title={s.title}>
  <header class="mb-6">
    <div class="text-sm text-gray-500">{s.kind} · {s.status}</div>
    <h1 class="text-3xl font-bold mt-1">{s.title}</h1>
    {s.synopsis && <p class="mt-3 text-gray-700">{s.synopsis}</p>}
  </header>

  {isShort && first ? (
    <article class="prose max-w-none" set:html={first.contentHtml ?? ""} />
  ) : (
    <ul class="divide-y border rounded">
      {chapters.length === 0 && <li class="p-4 text-gray-500">아직 등록된 화가 없습니다.</li>}
      {chapters.map((c) => (
        <li class="p-4 hover:bg-gray-50">
          <a href={`/s/${s.slug}/${c.number}`} class="flex justify-between">
            <span>
              <span class="text-gray-500 mr-3">{c.number}화</span>
              <span class="font-medium">{c.title}</span>
            </span>
            {c.status !== "발행" && (
              <span class="text-xs text-amber-600">{c.status}</span>
            )}
          </a>
        </li>
      ))}
    </ul>
  )}
</Layout>
