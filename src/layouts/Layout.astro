---
import "../styles/global.css";

interface Props {
  title?: string;
  scope?: "reader" | "admin";
}

const { title = "Kosmos", scope = "reader" } = Astro.props;
const pageTitle = title === "Kosmos" ? title : `${title} · Kosmos`;
const isAdmin = scope === "admin";
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body class={`min-h-screen antialiased ${isAdmin ? "admin-scope" : ""}`}>
    <header class="border-b border-gray-200/70 backdrop-blur bg-[color:var(--color-paper)]/80 sticky top-0 z-10">
      <nav class="mx-auto max-w-5xl flex items-center gap-6 px-5 py-4">
        <a href="/" class="wordmark text-xl hover:opacity-80">Kosmos</a>
        <div class="hidden sm:flex gap-5 text-sm text-gray-600">
          <a href="/" class="hover:text-gray-900">작품</a>
          <a href="/wiki" class="hover:text-gray-900">위키</a>
        </div>
        <form action="/search" method="get" class="ml-auto">
          <input
            type="search"
            name="q"
            placeholder="검색"
            class="w-28 sm:w-44 px-3 py-1 text-sm border border-gray-200 rounded-full bg-white/60 focus:outline-none focus:border-[color:var(--color-accent)] focus:bg-white focus:w-56 transition-all"
          />
        </form>
        <a
          href="/admin"
          class="text-xs text-gray-500 hover:text-gray-900 border border-gray-200 rounded-full px-3 py-1"
        >
          관리
        </a>
      </nav>
    </header>

    <main class="mx-auto max-w-3xl px-5 py-10">
      <slot />
    </main>

    <footer class="mx-auto max-w-5xl px-5 py-10 text-xs text-gray-400 border-t border-gray-200/70 mt-16">
      <div class="flex justify-between">
        <span>© Kosmos</span>
        <span class="wordmark">Kosmos</span>
      </div>
    </footer>

    <script>
      // Click-to-reveal for spoiler marks on reader pages
      document.addEventListener("click", (e) => {
        const el = (e.target as HTMLElement | null)?.closest?.(".spoiler");
        if (el && !el.closest(".ProseMirror")) {
          el.classList.toggle("revealed");
        }
      });

      // Footnote auto-numbering + list rendering on reader pages
      (function renderFootnotes() {
        document.querySelectorAll("article").forEach((article) => {
          const sups = article.querySelectorAll<HTMLElement>("sup.footnote[data-footnote]");
          if (sups.length === 0) return;

          const ol = document.createElement("ol");
          ol.className = "footnotes";

          sups.forEach((sup, i) => {
            const n = i + 1;
            sup.textContent = "";
            const markLink = document.createElement("a");
            markLink.href = `#fn-body-${n}`;
            markLink.id = `fn-mark-${n}`;
            markLink.textContent = `[${n}]`;
            sup.appendChild(markLink);

            const li = document.createElement("li");
            li.id = `fn-body-${n}`;
            li.textContent = sup.dataset.footnoteContent ?? "";
            const back = document.createElement("a");
            back.className = "backref";
            back.href = `#fn-mark-${n}`;
            back.textContent = "↩";
            li.appendChild(document.createTextNode(" "));
            li.appendChild(back);
            ol.appendChild(li);
          });

          const title = document.createElement("h3");
          title.className = "footnotes-title";
          title.textContent = "주석";
          article.appendChild(title);
          article.appendChild(ol);
        });
      })();
    </script>
  </body>
</html>
