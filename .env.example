# ----- Database (libSQL / SQLite) -----
# Local dev: a file path is fine
DATABASE_URL=file:./local.db
# Only required when using a remote libSQL (e.g. Turso)
# DATABASE_AUTH_TOKEN=

# ----- Better-Auth -----
# Generate a strong random string (e.g. `openssl rand -hex 32`)
BETTER_AUTH_SECRET=
# Must match the URL the browser hits (no trailing slash)
BETTER_AUTH_URL=http://localhost:4321

# ----- Anthropic / Claude -----
# Required only when AI features are used
ANTHROPIC_API_KEY=
